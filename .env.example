# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git - it's already in .gitignore

# Google Gemini API Key (Auth keys start with AQ.; legacy keys start with AIzaSy)
# Get your API key from: https://aistudio.google.com/apikey
# Use "Copy key" and paste the full value including the AQ. prefix
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs API Key (optional local override; production keys are managed in Super Admin)
# Create at https://elevenlabs.io/app/settings/api-keys — enable "Text to Speech" permission
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Firebase Configuration
# Get these values from your Firebase project settings
# https://console.firebase.google.com/project/mathtatag-capstone-app/settings/general
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=mathtatag-capstone-app.firebaseapp.com
FIREBASE_DATABASE_URL=https://mathtatag-capstone-app-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=mathtatag-capstone-app
FIREBASE_STORAGE_BUCKET=mathtatag-capstone-app.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id
